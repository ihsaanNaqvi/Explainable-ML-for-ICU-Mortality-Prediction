# Environment Configuration for ICU XAI Research
# Copy this file to .env and fill in your values

# Data paths
DATA_DIR=./data
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed

# Model configuration
RANDOM_SEED=42
TEST_SIZE=0.2
VAL_SIZE=0.1

# XGBoost parameters
XGBOOST_N_ESTIMATORS=100
XGBOOST_MAX_DEPTH=5
XGBOOST_LEARNING_RATE=0.1

# Neural network parameters
BATCH_SIZE=32
EPOCHS=100
LEARNING_RATE=0.001

# Output paths
OUTPUT_DIR=./outputs
FIGURES_DIR=./outputs/figures
MODELS_DIR=./outputs/models
